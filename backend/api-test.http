###############################################################################
# PocketFolio API 測試檔案 (Phase 3 - 多用戶版本)
# 
# 重要：所有 API 都需要 Authorization Header（除了 /api/auth/**）
###############################################################################

### 環境變數設定
@baseUrl = http://localhost:8080
@contentType = application/json

# 測試用戶 1
@user1Email = alice@example.com
@user1Password = password123
@user1Token = eyJhbGciOiJIUzUxMiJ9.eyJzdWIiOiJhbGljZUBleGFtcGxlLmNvbSIsImlhdCI6MTc3MzQ5MDMxMCwiZXhwIjoxNzczNTc2NzEwfQ.rvGO1qR9RaXTHNEa-DUym3c8_usV5g4rvQhRQj8L9uWYVmvJvE1jCERmRFtomf1zZEsZLwX8ieyigLBzOUZBYw

# 測試用戶 2
@user2Email = bob@example.com
@user2Password = password456
@user2Token = eyJhbGciOiJIUzUxMiJ9.eyJzdWIiOiJib2JAZXhhbXBsZS5jb20iLCJpYXQiOjE3NzMzMTgwMjUsImV4cCI6MTc3MzQwNDQyNX0.sseWd06Njam4BqlEg1t_FtH78trV7YU8vTmstS4xbVaGnumw9ZYfuFP3ZwpUnJGVhBy2NyUtjoq4fjVe6CN1VQ

# 資源 ID（執行後更新）
@categoryId = f32d108b-a9fd-4f0a-ad21-5d91bfc0bec7
@accountId = f5a37384-8b60-43ce-94d3-45dd44a8d179
@transactionId = 09574025-babc-4c0b-a9c8-eb8651d95764
@assetId = 1a0528f8-6dba-4eb3-bfff-670152e06eda


###############################################################################
# STEP 1: 註冊與登入
###############################################################################

### 1-1. 註冊用戶 Alice
POST {{baseUrl}}/api/auth/register
Content-Type: {{contentType}}

{
  "email": "{{user1Email}}",
  "username": "Alice",
  "password": "{{user1Password}}"
}
# 成功後複製 token → @user1Token

### 1-2. 註冊用戶 Bob
POST {{baseUrl}}/api/auth/register
Content-Type: {{contentType}}

{
  "email": "{{user2Email}}",
  "username": "Bob",
  "password": "{{user2Password}}"
}
# 成功後複製 token → @user2Token

### 1-3. Alice 登入
POST {{baseUrl}}/api/auth/login
Content-Type: {{contentType}}

{
  "email": "{{user1Email}}",
  "password": "{{user1Password}}"
}

### 1-4. Bob 登入
POST {{baseUrl}}/api/auth/login
Content-Type: {{contentType}}

{
  "email": "{{user2Email}}",
  "password": "{{user2Password}}"
}


###############################################################################
# STEP 2: Alice 建立基礎資料
###############################################################################

### 2-1. Alice 建立收入類別「薪資」
POST {{baseUrl}}/api/categories
Authorization: Bearer {{user1Token}}
Content-Type: {{contentType}}

{
  "name": "薪資",
  "type": "INCOME",
  "description": "每月固定薪水"
}
# 複製 id → @categoryId

### 2-2. Alice 建立支出類別「食物」
POST {{baseUrl}}/api/categories
Authorization: Bearer {{user1Token}}
Content-Type: {{contentType}}

{
  "name": "食物",
  "type": "EXPENSE"
}

### 2-3. Alice 建立銀行帳戶
POST {{baseUrl}}/api/accounts
Authorization: Bearer {{user1Token}}
Content-Type: {{contentType}}

{
  "name": "台新銀行",
  "type": "BANK",
  "initialBalance": 10000,
  "description": "Alice 的薪轉戶"
}
# 複製 id → @accountId

### 2-4. Alice 建立現金帳戶
POST {{baseUrl}}/api/accounts
Authorization: Bearer {{user1Token}}
Content-Type: {{contentType}}

{
  "name": "錢包現金",
  "type": "CASH",
  "initialBalance": 2000
}

### 2-5. Alice 查詢自己的所有類別
GET {{baseUrl}}/api/categories
Authorization: Bearer {{user1Token}}
# 應該看到 2 個類別

### 2-6. Alice 查詢自己的所有帳戶
GET {{baseUrl}}/api/accounts
Authorization: Bearer {{user1Token}}
# 應該看到 2 個帳戶


###############################################################################
# STEP 3: Bob 建立自己的資料
###############################################################################

### 3-1. Bob 建立收入類別「兼職」
POST {{baseUrl}}/api/categories
Authorization: Bearer {{user2Token}}
Content-Type: {{contentType}}

{
  "name": "兼職",
  "type": "INCOME"
}

### 3-2. Bob 建立支出類別「交通」
POST {{baseUrl}}/api/categories
Authorization: Bearer {{user2Token}}
Content-Type: {{contentType}}

{
  "name": "交通",
  "type": "EXPENSE"
}

### 3-3. Bob 建立銀行帳戶
POST {{baseUrl}}/api/accounts
Authorization: Bearer {{user2Token}}
Content-Type: {{contentType}}

{
  "name": "中國信託",
  "type": "BANK",
  "initialBalance": 5000,
  "description": "Bob 的銀行帳戶"
}

### 3-4. Bob 查詢自己的所有類別
GET {{baseUrl}}/api/categories
Authorization: Bearer {{user2Token}}
# 應該只看到 Bob 的 2 個類別（看不到 Alice 的）

### 3-5. Bob 查詢自己的所有帳戶
GET {{baseUrl}}/api/accounts
Authorization: Bearer {{user2Token}}
# 應該只看到 Bob 的 1 個帳戶（看不到 Alice 的）


###############################################################################
# STEP 4: 測試資料隔離 ✨ 重點測試
###############################################################################

### 4-1. Alice 建立交易
POST {{baseUrl}}/api/transactions
Authorization: Bearer {{user1Token}}
Content-Type: {{contentType}}

{
  "amount": 45000,
  "note": "Alice 的二月薪水",
  "date": "2026-02-25",
  "categoryId": "{{categoryId}}",
  "accountId": "{{accountId}}"
}
# 複製 id → @transactionId

### 4-2. Alice 查詢自己的交易
GET {{baseUrl}}/api/transactions
Authorization: Bearer {{user1Token}}
# 應該看到 1 筆交易

### 4-3. Bob 查詢自己的交易
GET {{baseUrl}}/api/transactions
Authorization: Bearer {{user2Token}}
# 應該看到 0 筆交易（看不到 Alice 的）

### 4-4. Bob 嘗試查詢 Alice 的交易（應該失敗）
GET {{baseUrl}}/api/transactions/{{transactionId}}
Authorization: Bearer {{user2Token}}
# 預期：404 Not Found（找不到交易）

### 4-5. Bob 嘗試刪除 Alice 的交易（應該失敗）
DELETE {{baseUrl}}/api/transactions/{{transactionId}}
Authorization: Bearer {{user2Token}}
# 預期：404 Not Found

### 4-6. Bob 嘗試使用 Alice 的類別建立交易（應該失敗）
POST {{baseUrl}}/api/transactions
Authorization: Bearer {{user2Token}}
Content-Type: {{contentType}}

{
  "amount": 1000,
  "note": "嘗試使用 Alice 的類別",
  "date": "2026-02-25",
  "categoryId": "{{categoryId}}"
}
# 預期：400 或 404（無權使用此類別）

### 4-7. Bob 嘗試使用 Alice 的帳戶建立交易（應該失敗）
POST {{baseUrl}}/api/transactions
Authorization: Bearer {{user2Token}}
Content-Type: {{contentType}}

{
  "amount": 1000,
  "note": "嘗試使用 Alice 的帳戶",
  "date": "2026-02-25",
  "accountId": "{{accountId}}"
}
# 預期：400 或 404（無權使用此帳戶）


###############################################################################
# STEP 5: Alice 建立完整測試資料
###############################################################################

### 5-1. Alice 記錄食物支出
POST {{baseUrl}}/api/transactions
Authorization: Bearer {{user1Token}}
Content-Type: {{contentType}}

{
  "amount": 150,
  "note": "午餐",
  "date": "2026-02-23",
  "categoryId": "3869a4b6-533c-4191-9f46-9af953021881",
  "accountId": "{{accountId}}"
}

### 5-2. Alice 查看銀行帳戶餘額
GET {{baseUrl}}/api/accounts/{{accountId}}
Authorization: Bearer {{user1Token}}
# currentBalance 應該 = 10000 + 45000 - 150 = 54850

### 5-3. Alice 查詢二月統計
GET {{baseUrl}}/api/statistics/monthly/2026/2
Authorization: Bearer {{user1Token}}
# 應該顯示：總收入 45000，總支出 150

### 5-4. Alice 查詢所有帳戶餘額
GET {{baseUrl}}/api/statistics/account-balances
Authorization: Bearer {{user1Token}}


###############################################################################
# STEP 6: 投資帳戶測試（Alice）
###############################################################################

### 6-1. Alice 建立投資帳戶
POST {{baseUrl}}/api/accounts
Authorization: Bearer {{user1Token}}
Content-Type: {{contentType}}

{
  "name": "富邦證券",
  "type": "INVESTMENT",
  "initialBalance": 0,
  "description": "Alice 的股票帳戶"
}
# 複製投資帳戶 id

### 6-2. Alice 新增資產 - 台積電
POST {{baseUrl}}/api/assets
Authorization: Bearer {{user1Token}}
Content-Type: {{contentType}}

{
  "accountId": "8e57ddd9-1c1b-4d0f-b5e1-8c226a571c29",
  "type": "STOCK",
  "symbol": "2330.TW",
  "name": "台積電",
  "quantity": 100,
  "costPrice": 600
}

### 6-3. Alice 查詢投資帳戶的資產
GET {{baseUrl}}/api/assets/account/8e57ddd9-1c1b-4d0f-b5e1-8c226a571c29
Authorization: Bearer {{user1Token}}

### 6-4. Bob 嘗試查詢 Alice 的資產（應該失敗）
GET {{baseUrl}}/api/assets/account/8e57ddd9-1c1b-4d0f-b5e1-8c226a571c29
Authorization: Bearer {{user2Token}}
# 預期：404 Not Found


###############################################################################
# STEP 7: 驗證完整資料隔離
###############################################################################

### 7-1. Alice 查詢總覽
# Categories
GET {{baseUrl}}/api/categories
Authorization: Bearer {{user1Token}}

# Accounts
GET {{baseUrl}}/api/accounts
Authorization: Bearer {{user1Token}}

# Transactions
GET {{baseUrl}}/api/transactions
Authorization: Bearer {{user1Token}}

### 7-2. Bob 查詢總覽
# Categories
GET {{baseUrl}}/api/categories
Authorization: Bearer {{user2Token}}

# Accounts
GET {{baseUrl}}/api/accounts
Authorization: Bearer {{user2Token}}

# Transactions
GET {{baseUrl}}/api/transactions
Authorization: Bearer {{user2Token}}

### 7-3. 驗證結果
# Alice 應該看到：自己的類別、帳戶、交易、資產
# Bob 應該看到：自己的類別、帳戶、交易（全部是空的或只有自己的）
# 兩個用戶的資料完全隔離 ✅


###############################################################################
# STEP 8: 錯誤處理測試
###############################################################################

### 8-1. 未登入查詢交易（應該失敗）
GET {{baseUrl}}/api/transactions
# 預期：401 Unauthorized

### 8-2. 使用錯誤 Token（應該失敗）
GET {{baseUrl}}/api/transactions
Authorization: Bearer invalid-token-here
# 預期：401 Unauthorized

### 8-3. Token 過期測試（需等 24 小時）
# 24 小時後使用舊 token 應該會失敗
```

---

## 🎯 執行測試流程

### Phase 1：基礎測試（5 分鐘）

依序執行：
```
1-1 → 註冊 Alice
1-2 → 註冊 Bob
複製兩個 token 到變數區
```

---

### Phase 2：建立資料（5 分鐘）

**Alice 的操作：**
```
2-1 → 建立類別「薪資」（複製 categoryId）
2-2 → 建立類別「食物」
2-3 → 建立帳戶「台新銀行」（複製 accountId）
2-4 → 建立帳戶「錢包現金」
2-5 → 查詢類別（應該看到 2 個）
2-6 → 查詢帳戶（應該看到 2 個）
```

**Bob 的操作：**
```
3-1 → 建立類別「兼職」
3-2 → 建立類別「交通」
3-3 → 建立帳戶「中國信託」
3-4 → 查詢類別（應該只看到自己的 2 個）✨
3-5 → 查詢帳戶（應該只看到自己的 1 個）✨
```

---

### Phase 3：資料隔離測試 🔥 重點
```
4-1 → Alice 建立交易（複製 transactionId）
4-2 → Alice 查詢交易（應該有 1 筆）
4-3 → Bob 查詢交易（應該是空的）✨
4-4 → Bob 查詢 Alice 的交易（應該 404）✨
4-5 → Bob 刪除 Alice 的交易（應該 404）✨
4-6 → Bob 使用 Alice 的類別（應該失敗）✨
4-7 → Bob 使用 Alice 的帳戶（應該失敗）✨
```

**預期結果：**
- ✅ Bob 完全看不到 Alice 的資料
- ✅ Bob 無法操作 Alice 的資源
- ✅ 資料完全隔離

---

### Phase 4：統計功能測試
```
5-1 → Alice 記錄食物支出
5-2 → Alice 查看帳戶餘額（應該正確計算）
5-3 → Alice 查詢二月統計（應該顯示收支）
5-4 → Alice 查詢所有帳戶餘額

###############################################################################
# PRICE API (價格更新與查詢)
###############################################################################

### ========== 查詢即時價格 ==========

### P1-1. 查詢比特幣價格
GET {{baseUrl}}/api/prices/BTC?type=CRYPTO
Authorization: Bearer {{user1Token}}

### P1-2. 查詢以太幣價格
GET {{baseUrl}}/api/prices/ETH?type=CRYPTO
Authorization: Bearer {{user1Token}}

### P1-3. 查詢台積電價格
GET {{baseUrl}}/api/prices/2330.TW?type=STOCK
Authorization: Bearer {{user1Token}}

### P1-4. 查詢蘋果股票價格
GET {{baseUrl}}/api/prices/AAPL?type=STOCK
Authorization: Bearer {{user1Token}}


### ========== 手動更新價格 ==========

### P2-1. 更新單一資產價格
POST {{baseUrl}}/api/prices/update/asset/{{assetId}}
Authorization: Bearer {{user1Token}}

### P2-2. 更新我的所有資產價格
POST {{baseUrl}}/api/prices/update/my-assets
Authorization: Bearer {{user1Token}}


### ========== 快取管理 ==========

### P3-1. 清除所有價格快取
DELETE {{baseUrl}}/api/prices/cache
Authorization: Bearer {{user1Token}}

### P3-2. 清除特定資產的價格快取
DELETE {{baseUrl}}/api/prices/cache/BTC?type=CRYPTO
Authorization: Bearer {{user1Token}}


###############################################################################
# 完整測試流程：價格更新
###############################################################################

### 情境：建立投資組合並更新價格

### PF1-1. Alice 建立投資帳戶
POST {{baseUrl}}/api/accounts
Authorization: Bearer {{user1Token}}
Content-Type: {{contentType}}

{
  "name": "加密貨幣錢包",
  "type": "INVESTMENT",
  "initialBalance": 0
}
# 複製投資帳戶 ID

### PF1-2. Alice 新增比特幣資產
POST {{baseUrl}}/api/assets
Authorization: Bearer {{user1Token}}
Content-Type: {{contentType}}

{
  "accountId": "cf89b1b3-c0e5-47e9-8395-7d5fb5588ab0",
  "type": "CRYPTO",
  "symbol": "BTC",
  "name": "比特幣",
  "quantity": 0.1,
  "costPrice": 50000,
  "note": "長期持有"
}
# 複製資產 ID → @assetId

### PF1-3. Alice 新增以太幣資產
POST {{baseUrl}}/api/assets
Authorization: Bearer {{user1Token}}
Content-Type: {{contentType}}

{
  "accountId": "cf89b1b3-c0e5-47e9-8395-7d5fb5588ab0",
  "type": "CRYPTO",
  "symbol": "ETH",
  "name": "以太幣",
  "quantity": 2,
  "costPrice": 3000
}

### PF1-4. 查詢比特幣即時價格（第一次會呼叫 API）
GET {{baseUrl}}/api/prices/BTC?type=CRYPTO
Authorization: Bearer {{user1Token}}

### PF1-5. 再次查詢比特幣價格（應該從 Redis 快取讀取）
GET {{baseUrl}}/api/prices/BTC?type=CRYPTO
Authorization: Bearer {{user1Token}}
# 查看 console log，應該顯示「從快取取得價格」

### PF1-6. 更新比特幣資產的價格
POST {{baseUrl}}/api/prices/update/asset/{{assetId}}
Authorization: Bearer {{user1Token}}
# 回應應包含：oldPrice, newPrice, changePercent

### PF1-7. 查詢資產（價格應該已更新）
GET {{baseUrl}}/api/assets/{{assetId}}
Authorization: Bearer {{user1Token}}
# currentPrice 應該是最新價格
# profitLoss 和 profitLossPercent 應該重新計算

### PF1-8. 更新所有資產價格
POST {{baseUrl}}/api/prices/update/my-assets
Authorization: Bearer {{user1Token}}
# 應該回傳兩筆更新結果（BTC + ETH）

### PF1-9. 查詢投資帳戶（餘額應該是所有資產市值）
GET {{baseUrl}}/api/accounts/cf89b1b3-c0e5-47e9-8395-7d5fb5588ab0
Authorization: Bearer {{user1Token}}
# currentBalance = BTC市值 + ETH市值
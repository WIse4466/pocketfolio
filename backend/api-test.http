###############################################################################
# PocketFolio API 測試檔案
# 使用方式：
# 1. 在 VS Code 安裝 REST Client 擴充套件
# 2. 點擊每個請求上方的 "Send Request" 執行
# 3. 結果會顯示在右側視窗
###############################################################################

### 環境變數設定
@baseUrl = http://localhost:8080
@contentType = application/json

# 將實際取得的 ID 貼在這裡，方便後續測試使用
@categoryId = 6099d922-b5a4-4da3-84f0-ed913d642024
@transactionId = d9ca2fe9-e868-4bb2-b695-9313717726c4


###############################################################################
# CATEGORY API
###############################################################################

### ========== Create ==========

### 1-1. 建立收入類別 - 薪資
POST {{baseUrl}}/api/categories
Content-Type: {{contentType}}

{
  "name": "薪資",
  "type": "INCOME",
  "description": "每月固定薪水"
}

### 1-2. 建立收入類別 - 投資收益
POST {{baseUrl}}/api/categories
Content-Type: {{contentType}}

{
  "name": "投資收益",
  "type": "INCOME",
  "description": "股票、基金等投資獲利"
}

### 1-3. 建立收入類別 - 獎金
POST {{baseUrl}}/api/categories
Content-Type: {{contentType}}

{
  "name": "獎金",
  "type": "INCOME"
}

### 1-4. 建立支出類別 - 食物
POST {{baseUrl}}/api/categories
Content-Type: {{contentType}}

{
  "name": "食物",
  "type": "EXPENSE",
  "description": "三餐、零食、飲料"
}

### 1-5. 建立支出類別 - 交通
POST {{baseUrl}}/api/categories
Content-Type: {{contentType}}

{
  "name": "交通",
  "type": "EXPENSE",
  "description": "捷運、公車、計程車、加油"
}

### 1-6. 建立支出類別 - 娛樂
POST {{baseUrl}}/api/categories
Content-Type: {{contentType}}

{
  "name": "娛樂",
  "type": "EXPENSE",
  "description": "電影、遊戲、旅遊"
}

### 1-7. 建立支出類別 - 投資
POST {{baseUrl}}/api/categories
Content-Type: {{contentType}}

{
  "name": "投資",
  "type": "EXPENSE",
  "description": "購買股票、基金等"
}

### 1-8. 建立支出類別 - 房租
POST {{baseUrl}}/api/categories
Content-Type: {{contentType}}

{
  "name": "房租",
  "type": "EXPENSE"
}

### ========== Read ==========

### 2-1. 查詢所有類別
GET {{baseUrl}}/api/categories

### 2-2. 只查詢收入類別
GET {{baseUrl}}/api/categories?type=INCOME

### 2-3. 只查詢支出類別
GET {{baseUrl}}/api/categories?type=EXPENSE

### 2-4. 查詢單筆類別（記得先執行上面的 Create，複製回應的 id 貼到變數）
GET {{baseUrl}}/api/categories/{{categoryId}}

### ========== Update ==========

### 3-1. 更新類別 - 修改名稱和描述
PUT {{baseUrl}}/api/categories/{{categoryId}}
Content-Type: {{contentType}}

{
  "name": "伙食費",
  "type": "EXPENSE",
  "description": "更新過的描述：包含早午晚餐"
}

### 3-2. 更新類別 - 只改描述
PUT {{baseUrl}}/api/categories/{{categoryId}}
Content-Type: {{contentType}}

{
  "name": "食物",
  "type": "EXPENSE",
  "description": "只更新描述欄位"
}

### ========== Delete ==========

### 4-1. 刪除類別（會回傳 204 No Content）
DELETE {{baseUrl}}/api/categories/{{categoryId}}

### ========== 錯誤測試 ==========

### 5-1. 測試驗證錯誤 - 名稱為空
POST {{baseUrl}}/api/categories
Content-Type: {{contentType}}

{
  "name": "",
  "type": "INCOME"
}
# 預期：400 Bad Request，訊息包含 "類別名稱不能為空"

### 5-2. 測試驗證錯誤 - 類型為空
POST {{baseUrl}}/api/categories
Content-Type: {{contentType}}

{
  "name": "測試類別"
}
# 預期：400 Bad Request，訊息包含 "類別類型不能為空"

### 5-3. 測試重複名稱（需先建立一次薪資類別，再執行這個）
POST {{baseUrl}}/api/categories
Content-Type: {{contentType}}

{
  "name": "薪資",
  "type": "INCOME"
}
# 預期：400 Bad Request，訊息包含 "類別名稱「薪資」已存在"

### 5-4. 測試查詢不存在的 ID
GET {{baseUrl}}/api/categories/00000000-0000-0000-0000-000000000000
# 預期：404 Not Found

### 5-5. 測試更新不存在的 ID
PUT {{baseUrl}}/api/categories/00000000-0000-0000-0000-000000000000
Content-Type: {{contentType}}

{
  "name": "測試",
  "type": "INCOME"
}
# 預期：404 Not Found

### 5-6. 測試刪除不存在的 ID
DELETE {{baseUrl}}/api/categories/00000000-0000-0000-0000-000000000000
# 預期：404 Not Found


###############################################################################
# TRANSACTION API (擴充版 - 包含類別與帳戶關聯)
###############################################################################

### 變數：先建立類別和帳戶，複製 ID 到這裡
@salaryCategory = 79adf2ee-c43f-4bab-9e92-ec9ccb6ba6d3
@foodCategory = 3804d718-9e37-4c3c-82a0-8b874e969a92
@transportCategory = 5bbf89fc-0db9-42f3-98af-e147ee07843c
@cashAccount = b9d771fa-413f-44b9-b0aa-d09b7478aaf2
@bankAccount = dcb09728-c42e-4042-9bfd-46c12f3d48d1

### ========== Create Transactions (含關聯) ==========

### T1-1. 建立收入交易 - 薪資入帳到銀行
POST {{baseUrl}}/api/transactions
Content-Type: {{contentType}}

{
  "amount": 45000,
  "note": "二月薪水",
  "date": "2026-02-25",
  "categoryId": "{{salaryCategory}}",
  "accountId": "{{bankAccount}}"
}

### T1-2. 建立支出交易 - 食物（從現金支付）
POST {{baseUrl}}/api/transactions
Content-Type: {{contentType}}

{
  "amount": 150,
  "note": "午餐便當",
  "date": "2026-02-23",
  "categoryId": "{{foodCategory}}",
  "accountId": "{{cashAccount}}"
}

### T1-3. 建立支出交易 - 交通（從銀行扣款）
POST {{baseUrl}}/api/transactions
Content-Type: {{contentType}}

{
  "amount": 500,
  "note": "捷運月票",
  "date": "2026-02-01",
  "categoryId": "{{transportCategory}}",
  "accountId": "{{bankAccount}}"
}

### T1-4. 建立交易 - 只有類別，沒有帳戶
POST {{baseUrl}}/api/transactions
Content-Type: {{contentType}}

{
  "amount": 80,
  "note": "早餐",
  "date": "2026-02-23",
  "categoryId": "{{foodCategory}}"
}

### T1-5. 建立交易 - 只有帳戶，沒有類別（未分類）
POST {{baseUrl}}/api/transactions
Content-Type: {{contentType}}

{
  "amount": 200,
  "note": "未分類支出",
  "date": "2026-02-22",
  "accountId": "{{cashAccount}}"
}

### T1-6. 建立交易 - 沒有類別也沒有帳戶
POST {{baseUrl}}/api/transactions
Content-Type: {{contentType}}

{
  "amount": 50,
  "note": "臨時支出",
  "date": "2026-02-21"
}

### T1-7. 批次建立測試資料 - 食物支出
POST {{baseUrl}}/api/transactions
Content-Type: {{contentType}}

{
  "amount": 120,
  "note": "晚餐",
  "date": "2026-02-23",
  "categoryId": "{{foodCategory}}",
  "accountId": "{{cashAccount}}"
}

### T1-8. 批次建立測試資料 - 早餐
POST {{baseUrl}}/api/transactions
Content-Type: {{contentType}}

{
  "amount": 60,
  "note": "早餐",
  "date": "2026-02-24",
  "categoryId": "{{foodCategory}}",
  "accountId": "{{cashAccount}}"
}

### T1-9. 批次建立測試資料 - 交通
POST {{baseUrl}}/api/transactions
Content-Type: {{contentType}}

{
  "amount": 50,
  "note": "計程車",
  "date": "2026-02-20",
  "categoryId": "{{transportCategory}}",
  "accountId": "{{cashAccount}}"
}

### ========== Read Transactions (基本查詢) ==========

### T2-1. 查詢所有交易（預設分頁）
GET {{baseUrl}}/api/transactions

### T2-2. 查詢單筆交易（應顯示類別和帳戶資訊）
GET {{baseUrl}}/api/transactions/{{transactionId}}
# 回應應包含：categoryName, categoryType, accountName, accountType

### T2-3. 分頁查詢 - 第1頁，每頁5筆
GET {{baseUrl}}/api/transactions?page=0&size=5

### T2-4. 依日期升序排列
GET {{baseUrl}}/api/transactions?sort=date,asc

### T2-5. 依金額降序排列
GET {{baseUrl}}/api/transactions?sort=amount,desc

### ========== Read Transactions (依類別篩選) ==========

### T3-1. 查詢「食物」類別的所有交易
GET {{baseUrl}}/api/transactions?categoryId={{foodCategory}}

### T3-2. 查詢「交通」類別的所有交易
GET {{baseUrl}}/api/transactions?categoryId={{transportCategory}}

### T3-3. 查詢「薪資」類別的所有交易
GET {{baseUrl}}/api/transactions?categoryId={{salaryCategory}}

### ========== Read Transactions (依帳戶篩選) ==========

### T4-1. 查詢「現金」帳戶的所有交易
GET {{baseUrl}}/api/transactions?accountId={{cashAccount}}

### T4-2. 查詢「銀行」帳戶的所有交易
GET {{baseUrl}}/api/transactions?accountId={{bankAccount}}

### ========== Read Transactions (依日期範圍篩選) ==========

### T5-1. 查詢二月份的所有交易
GET {{baseUrl}}/api/transactions?startDate=2026-02-01&endDate=2026-02-28

### T5-2. 查詢最近7天的交易
GET {{baseUrl}}/api/transactions?startDate=2026-02-16&endDate=2026-02-23

### T5-3. 查詢本週的交易
GET {{baseUrl}}/api/transactions?startDate=2026-02-17&endDate=2026-02-23

### ========== Read Transactions (組合篩選) ==========

### T6-1. 查詢「食物」類別 + 二月份
GET {{baseUrl}}/api/transactions?categoryId={{foodCategory}}&startDate=2026-02-01&endDate=2026-02-28

### T6-2. 查詢「現金」帳戶 + 二月份
GET {{baseUrl}}/api/transactions?accountId={{cashAccount}}&startDate=2026-02-01&endDate=2026-02-28

### T6-3. 查詢「交通」類別 + 「銀行」帳戶 + 二月份（複雜組合）
# 注意：目前 API 不支援同時篩選類別和帳戶，這是進階功能
# 可以先篩選類別，或先篩選帳戶
GET {{baseUrl}}/api/transactions?categoryId={{transportCategory}}&startDate=2026-02-01&endDate=2026-02-28

### ========== Update Transactions ==========

### T7-1. 更新交易 - 修改金額和類別
PUT {{baseUrl}}/api/transactions/{{transactionId}}
Content-Type: {{contentType}}

{
  "amount": 180,
  "note": "午餐便當（修正金額）",
  "date": "2026-02-23",
  "categoryId": "{{foodCategory}}",
  "accountId": "{{cashAccount}}"
}

### T7-2. 更新交易 - 改變帳戶
PUT {{baseUrl}}/api/transactions/{{transactionId}}
Content-Type: {{contentType}}

{
  "amount": 150,
  "note": "改用銀行支付",
  "date": "2026-02-23",
  "categoryId": "{{foodCategory}}",
  "accountId": "{{bankAccount}}"
}

### T7-3. 更新交易 - 清除類別（設為 null）
PUT {{baseUrl}}/api/transactions/{{transactionId}}
Content-Type: {{contentType}}

{
  "amount": 100,
  "note": "移除類別",
  "date": "2026-02-23",
  "accountId": "{{cashAccount}}"
}

### T7-4. 更新交易 - 清除帳戶
PUT {{baseUrl}}/api/transactions/{{transactionId}}
Content-Type: {{contentType}}

{
  "amount": 100,
  "note": "移除帳戶",
  "date": "2026-02-23",
  "categoryId": "{{foodCategory}}"
}

### ========== Delete Transactions ==========

### T8-1. 刪除交易
DELETE {{baseUrl}}/api/transactions/{{transactionId}}

### ========== Error Tests ==========

### T9-1. 建立交易 - 類別 ID 不存在
POST {{baseUrl}}/api/transactions
Content-Type: {{contentType}}

{
  "amount": 100,
  "date": "2026-02-23",
  "categoryId": "00000000-0000-0000-0000-000000000000"
}
# 預期：404 Not Found，找不到類別

### T9-2. 建立交易 - 帳戶 ID 不存在
POST {{baseUrl}}/api/transactions
Content-Type: {{contentType}}

{
  "amount": 100,
  "date": "2026-02-23",
  "accountId": "00000000-0000-0000-0000-000000000000"
}
# 預期：404 Not Found，找不到帳戶

### T9-3. 查詢交易 - 類別 ID 不存在
GET {{baseUrl}}/api/transactions?categoryId=00000000-0000-0000-0000-000000000000
# 預期：404 Not Found

### T9-4. 查詢交易 - 帳戶 ID 不存在
GET {{baseUrl}}/api/transactions?accountId=00000000-0000-0000-0000-000000000000
# 預期：404 Not Found


###############################################################################
# 整合測試情境 - 完整記帳流程
###############################################################################

### ========== 情境：發薪日完整記帳 ==========

### IT1-1. 先建立收入類別「薪資」
POST {{baseUrl}}/api/categories
Content-Type: {{contentType}}

{
  "name": "薪資",
  "type": "INCOME",
  "description": "每月固定薪水"
}
# 複製回應的 id → @salaryCategory

### IT1-2. 建立銀行帳戶
POST {{baseUrl}}/api/accounts
Content-Type: {{contentType}}

{
  "name": "台新銀行",
  "type": "BANK",
  "initialBalance": 10000,
  "description": "薪轉戶"
}
# 複製回應的 id → @bankAccount

### IT1-3. 記錄薪資入帳
POST {{baseUrl}}/api/transactions
Content-Type: {{contentType}}

{
  "amount": 45000,
  "note": "二月薪水",
  "date": "2026-02-25",
  "categoryId": "{{salaryCategory}}",
  "accountId": "{{bankAccount}}"
}

### IT1-4. 查看銀行帳戶（餘額應該是 initialBalance + 交易）
GET {{baseUrl}}/api/accounts/{{bankAccount}}
# currentBalance 應該顯示正確餘額（Phase 2 最後會實作）

### ========== 情境：日常消費記帳 ==========

### IT2-1. 建立支出類別「食物」
POST {{baseUrl}}/api/categories
Content-Type: {{contentType}}

{
  "name": "食物",
  "type": "EXPENSE"
}
# 複製 id → @foodCategory

### IT2-2. 建立現金帳戶
POST {{baseUrl}}/api/accounts
Content-Type: {{contentType}}

{
  "name": "錢包現金",
  "type": "CASH",
  "initialBalance": 2000
}
# 複製 id → @cashAccount

### IT2-3. 記錄早餐消費
POST {{baseUrl}}/api/transactions
Content-Type: {{contentType}}

{
  "amount": 60,
  "note": "早餐 - 三明治",
  "date": "2026-02-23",
  "categoryId": "{{foodCategory}}",
  "accountId": "{{cashAccount}}"
}

### IT2-4. 記錄午餐消費
POST {{baseUrl}}/api/transactions
Content-Type: {{contentType}}

{
  "amount": 150,
  "note": "午餐 - 便當",
  "date": "2026-02-23",
  "categoryId": "{{foodCategory}}",
  "accountId": "{{cashAccount}}"
}

### IT2-5. 記錄晚餐消費
POST {{baseUrl}}/api/transactions
Content-Type: {{contentType}}

{
  "amount": 200,
  "note": "晚餐 - 火鍋",
  "date": "2026-02-23",
  "categoryId": "{{foodCategory}}",
  "accountId": "{{cashAccount}}"
}

### IT2-6. 查看今天的食物支出
GET {{baseUrl}}/api/transactions?categoryId={{foodCategory}}&startDate=2026-02-23&endDate=2026-02-23

### IT2-7. 查看現金帳戶的所有交易
GET {{baseUrl}}/api/transactions?accountId={{cashAccount}}

### ========== 情境：月底對帳 ==========

### IT3-1. 查詢二月份所有收入（收入類別）
# 先建立所有收入類別的交易，然後查詢
GET {{baseUrl}}/api/transactions?categoryId={{salaryCategory}}&startDate=2026-02-01&endDate=2026-02-28

### IT3-2. 查詢二月份所有食物支出
GET {{baseUrl}}/api/transactions?categoryId={{foodCategory}}&startDate=2026-02-01&endDate=2026-02-28

### IT3-3. 查詢銀行帳戶的二月份交易明細
GET {{baseUrl}}/api/transactions?accountId={{bankAccount}}&startDate=2026-02-01&endDate=2026-02-28

### IT3-4. 查看所有帳戶餘額
GET {{baseUrl}}/api/accounts


###############################################################################
# 快速建立完整測試資料
###############################################################################

### ========== 執行順序建議 ==========
# 1. 建立類別（1-1 到 1-8）
# 2. 建立帳戶（A1-1 到 A1-4）
# 3. 複製 ID 到變數區
# 4. 建立交易（T1-1 到 T1-9）
# 5. 測試各種查詢（T2 到 T6）

### QS1. 快速建立：薪資類別 + 銀行帳戶 + 薪資入帳
# 依序執行：IT1-1 → IT1-2 → IT1-3

### QS2. 快速建立：食物類別 + 現金帳戶 + 一日三餐
# 依序執行：IT2-1 → IT2-2 → IT2-3 → IT2-4 → IT2-5

### QS3. 驗證關聯正確性
# 執行任一筆 T2-2，檢查回應是否包含：
# - categoryId, categoryName, categoryType
# - accountId, accountName, accountType


###############################################################################
# 整合測試情境
###############################################################################

### ========== 情境一：建立完整的收支記錄 ==========

### S1-1. 先建立收入類別
POST {{baseUrl}}/api/categories
Content-Type: {{contentType}}

{
  "name": "兼職收入",
  "type": "INCOME"
}
# 複製回應的 id，用於下一步

### S1-2. 再建立對應的交易（未來 Phase 2 會綁定 categoryId）
POST {{baseUrl}}/api/transactions
Content-Type: {{contentType}}

{
  "amount": 5000,
  "note": "週末家教",
  "date": "2026-02-23"
}

### ========== 情境二：月底檢查所有交易 ==========

### S2-1. 查詢所有交易（檢查這個月花了多少）
GET {{baseUrl}}/api/transactions?page=0&size=50&sort=date,desc

### S2-2. 查詢所有支出類別（看看支出都花在哪些項目）
GET {{baseUrl}}/api/categories?type=EXPENSE

### ========== 情境三：修正錯誤的記帳 ==========

### S3-1. 查詢特定交易
GET {{baseUrl}}/api/transactions/{{transactionId}}

### S3-2. 發現金額錯誤，更新
PUT {{baseUrl}}/api/transactions/{{transactionId}}
Content-Type: {{contentType}}

{
  "amount": 120,
  "note": "修正金額：原本記錯了",
  "date": "2026-02-23"
}

### S3-3. 確認更新成功
GET {{baseUrl}}/api/transactions/{{transactionId}}


###############################################################################
# 壓力測試（選用）
###############################################################################

### 批次建立 10 筆交易（手動執行 10 次）
POST {{baseUrl}}/api/transactions
Content-Type: {{contentType}}

{
  "amount": 100,
  "note": "批次測試資料",
  "date": "2026-02-20"
}

###############################################################################
# ACCOUNT API
###############################################################################

### ========== Create ==========

### A1-1. 建立現金帳戶
POST {{baseUrl}}/api/accounts
Content-Type: {{contentType}}

{
  "name": "錢包現金",
  "type": "CASH",
  "initialBalance": 5000,
  "description": "隨身錢包"
}

### A1-2. 建立銀行帳戶
POST {{baseUrl}}/api/accounts
Content-Type: {{contentType}}

{
  "name": "台新銀行",
  "type": "BANK",
  "initialBalance": 50000,
  "description": "薪轉戶"
}

### A1-3. 建立信用卡帳戶（負值表示欠款）
POST {{baseUrl}}/api/accounts
Content-Type: {{contentType}}

{
  "name": "花旗信用卡",
  "type": "CREDIT_CARD",
  "initialBalance": -15000,
  "description": "本期帳單"
}

### A1-4. 建立投資帳戶
POST {{baseUrl}}/api/accounts
Content-Type: {{contentType}}

{
  "name": "富邦證券",
  "type": "INVESTMENT",
  "initialBalance": 100000,
  "description": "股票投資帳戶"
}

### ========== Read ==========

### A2-1. 查詢所有帳戶
GET {{baseUrl}}/api/accounts

### A2-2. 只查詢銀行帳戶
GET {{baseUrl}}/api/accounts?type=BANK

### A2-3. 只查詢投資帳戶
GET {{baseUrl}}/api/accounts?type=INVESTMENT

### A2-4. 搜尋帳戶（包含「銀行」關鍵字）
GET {{baseUrl}}/api/accounts?search=銀行

### A2-5. 查詢單筆帳戶
@accountId = 57319826-5771-4bc8-9a59-284456bdc45f
GET {{baseUrl}}/api/accounts/{{accountId}}

### ========== Update ==========

### A3-1. 更新帳戶資訊
PUT {{baseUrl}}/api/accounts/{{accountId}}
Content-Type: {{contentType}}

{
  "name": "台新 Richart",
  "type": "BANK",
  "initialBalance": 50000,
  "description": "數位帳戶"
}

### ========== Delete ==========

### A4-1. 刪除帳戶
DELETE {{baseUrl}}/api/accounts/{{accountId}}

### ========== 錯誤測試 ==========

